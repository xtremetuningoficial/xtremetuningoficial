# Copia este archivo a .env y completa los valores de tu proyecto de Supabase.
# Ver supabase/README.md para el paso a paso. Nunca subas el .env real a git.

# Panel: Project Settings → API → Project URL
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Panel: Project Settings → API → anon public key
# Segura de exponer en el navegador: el acceso real lo controla RLS, no esta key.
VITE_SUPABASE_ANON_KEY=

# Panel: Project Settings → API → service_role key
# SECRETA. Solo la usa scripts/seed-products.ts en tu máquina (npm run db:seed).
# Nunca la uses en código de frontend ni la subas a git.
SUPABASE_SERVICE_ROLE_KEY=
